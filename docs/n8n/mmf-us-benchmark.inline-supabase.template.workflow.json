      "name": "Fetch NY Fed SOFR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        80,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "function phtDate() {\n  const parts = new Intl.DateTimeFormat('en-US', { timeZone: 'Asia/Manila', year: 'numeric', month: '2-digit', day: '2-digit' }).formatToParts(new Date());\n  const pick = (type) => parts.find((part) => part.type === type).value;\n  return pick('year') + '-' + pick('month') + '-' + pick('day');\n}\n\nconst raw = $json.refRates || {};\nconst sofr_ai = raw.find(r => r.type === 'SOFRAI');\nif (!sofr_ai || !sofr_ai.average90day) throw new Error('Missing SOFRAI 90-day average from NY Fed response');\n\nconst rate = Number(sofr_ai.average90day) / 100;\n\nreturn [{\n  json: {\n    key: 'US_TBILL_90D',\n    label: '90-Day SOFR Average (Proxy for US T-Bill)',\n    date: phtDate(),\n    rate: Number(rate.toFixed(6)),\n    source_url: 'https://markets.newyorkfed.org/api/rates/all/latest.json'\n  }\n}];"
      },
      "id": "0d20d4df-0599-4d69-a178-01e40ebfb7ee",
