  "nodes": [
    {
      "parameters": {},
      "id": "891180cb-cc2f-4dc2-8d6d-77a16f0da889",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -520,
